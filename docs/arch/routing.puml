@startuml routing

scale 1920*1080

actor Upstream
participant "Proxy Core" as P
participant "Plugin Modules" as PM
actor Downstream

== Routing decision ==
Upstream -> P : Incoming request / connection / packet
P -> PM : Consult plugins (`on_route`)
PM --> P : plugin route decision

alt upstream selected
    == Forwarding ==
    P -> Downstream : Forward via selected route

    alt downstream success
        Downstream --> P : Response / packet / stream data
        P -> Upstream : Deliver upstream
    else downstream failure
        Downstream ->x P : Timeout / reset / unreachable
        P -> Upstream : Propagate error / close
    end

else no upstream selected
    C --> P : No match
    P -> Upstream : Reject / error
end

@enduml
