@startuml tcp_udp

scale 1920*1080

actor Upstream
participant "L4 Proxy Module" as P
participant "Proxy core" as R
participant "Plugin Modules" as PM
actor Downstream

loop continuous data flow

Upstream -> P : Send packet
P -> R : Forward raw packet / stream chunk
R -> PM : Call hooks with current packet data

loop while MWs
    PM -> PM : Process / transform / inspect packet
end

alt middleware decides to forward
    PM -> R : Forward packet (possibly modified)
    R ->  : Consult TCP plugin modules (connection filter / on_route)
    PM --> R : decision
else middleware handles locally
    PM -> P : Generate packet / drop / terminate
end

R -> Downstream : Send packet
Downstream -> R : Raw packet / stream chunk
R -> PM : Forward packet / error signal if needed

loop while MWs
    PM -> PM : Process / transform / inspect packet
end

alt middleware forwards upstream
    PM -> P : Forward packet (modified or not)
else middleware handles locally
    PM -> P : Generate packet / drop / terminate
end

P -> Upstream : Send packet
end

== Error Handling ==
alt downstream failure
    Downstream ->x R : Connection reset / timeout
    R -> PM : Signal transport error
    loop while MWs
        PM -> PM : Handle error
    end
    PM -> P : Handle error (retry / close / synthesize data)
    P -> Upstream : Propagate error / close connection
end

@enduml
