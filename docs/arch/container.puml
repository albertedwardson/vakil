@startuml C4Container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
HIDE_STEREOTYPE()

title Container level

Person(upstream, "Upstream")
Person(controlOperator, "Control Operator", "Engineer managing proxy configuration")

System_Boundary(proxy, "Vakil") {

    package "Vakil (core)" {
        Container(core, "Proxy Core", "rust[pingora/rama/stabby]", "Core runtime, routing, plugin management")
        Container(l7, "HTTP Proxy Engine", "rust[pingora]", "HTTP/1.0–2 reverse proxy and lifecycle hooks")
        Container(l7mw, "HTTP Middleware Pipeline", "rust[pingora]", "Hook points for middleware provided by plugins")
        Container(l4, "L4 Proxy Engine", "rust[rama]", "TCP/UDP proxying and stream management")
        Container(l4filter, "L4 Filter Pipeline", "rust[rama]", "Hook points for L4 filters provided by plugins")
        Container(plugin_host, "Plugin Host", "rust[stabby]", "Loading and managing middleware and filters")
    }

    package "Plugins (external modules)" {
        Container(plugin_modules, "Plugin Modules", "dynamic libs", "Middleware, routing hooks, L4 filters")
    }
}

System_Ext(downstream, "Downstream Services", "HTTP and TCP/UDP backends")

Rel_R(upstream, l7, "HTTP traffic")
Rel_R(upstream, l4, "TCP and UDP traffic")

' ===== L7 data path =====
Rel_D(l7, l7mw, "Invokes")
Rel_R(l7mw, core, "Controls flow")

' ===== L4 data path =====
Rel_D(l4, l4filter, "Applies")
Rel_L(l4filter, core, "Controls flow")

' ===== Plugins =====
Rel_U(core, plugin_host, "Uses")
Rel_D(plugin_host, l7mw, "Provides middleware")
Rel_D(plugin_host, l4filter, "Provides filters")

' ===== Configuration =====
Rel_D(controlOperator, plugin_modules, "Defines behavior")
Rel_D(plugin_host, plugin_modules, "Loads")
Rel_D(plugin_host, core, "Configures")

' ===== Egress =====
Rel_D(core, downstream, "Forwards traffic")
